# Credentials & secrets
.credentials.json

# Session data (per-machine, ephemeral)
history.jsonl
sessions/
.spec-grounding/
session-env/
shell-snapshots/
paste-cache/
file-history/
ide/
debug/
cache/
downloads/
backups/
telemetry/
todos/
tasks/
plans/
plugins/

# Project-scoped memory (per-project, not shared)
projects/

# Unified memory store → 전용 repo(claude-memory)로 분리 (2026-06-15, DB-SoT 전환).
# memory.db(로컬 SoT)·dump.jsonl(전용 repo가 추적)·파생물 전부 config repo 에선 무시.
# root-anchored(/memory/): 코드 디렉토리 tools/memory/ 까지 무차별 매칭하지 않게 (2026-06-16).
/memory/

# NFS temp files
.nfs*

# MCP runtime cache (per-machine, ephemeral)
mcp-needs-auth-cache.json

# Cleanup timestamp (per-machine, ephemeral)
.last-cleanup

# CLI auto-update result + sync log + usage stats (per-machine, ephemeral — churn noise)
.last-update-result.json
.sync.log
stats-cache.json

# 일회성 진단 스냅샷 (로컬 참조용 — 공유 repo 미포함)
SKILL_AUDIT_*.md

# analyze-user 내부 — 전체 로컬 전용 (public repo 미포함).
# clone 해서 "바로 쓰는" 데는 DB store (memory.db / dump.jsonl) + user_profile/README 만 필요. (구 `user_profile/0*.md` 파일은 DB `type=profile` 레코드로 이관됨 — sub-agent 는 `mem profile <stem>` 로 Read.)
# _internal 은 프로필 제작·갱신용 산출물 (raw 분석 run·개인 원본 PDF·버전 스냅샷·metadata) — 개인정보 다수.
user_profile/_internal/
# assets 는 사용자 실제 연구 figure (pptx 추출 SVG 54장·원본 anchor PNG·primitives, ~42M, 일부 미공개) — 로컬 전용.
# pptx(ref_user_profile/figure_ppt/)에서 pdftocairo 로 언제든 재생성. clone 엔 불필요.
user_profile/assets/
.cwm_removal_backup/
.cache/
loops/*.log
loops/drill/results/
loops/drill/metrics.csv
.statusline-last.json
.statusline-last-out.txt
.dispatch/
.claude_reports/.pipeline-lock
.claude_reports/.untracked*

# loop 일시 hold 토글 (per-machine, 만료일 담긴 런타임 플래그)
loops/.hold

# Python 빌드 캐시
__pycache__/

# 분사 headless가 worktree에 남기는 nested agent-memory cruft 차단
/.claude/
