{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/agent-harness/adapters/codex/hooks/pretooluse-write-guard.py\"",
            "timeout": 30,
            "statusMessage": "Checking agent harness write guards"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/agent-harness/adapters/codex/hooks/posttooluse-design-check.py\"",
            "timeout": 30,
            "statusMessage": "Checking design HTML after write"
          }
        ]
      }
    ]
  }
}
